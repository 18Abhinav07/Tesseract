b:["$","$1","c",{"children":[["$","div",null,{"className":"animate-in fade-in duration-500","children":[["$","h1",null,{"children":"Architecture"}],["$","p",null,{"children":"Kredio separates capital logic from intelligence. EVM contracts handle deterministic settlement, token custody, and event emission. Wasm and PVM contracts handle computation: credit scoring, liquidation risk modelling, and yield allocation. A Node.js backend service layer coordinates off-chain activity without holding any protocol state."}],["$","h2",null,{"id":"layers","children":"Execution Layers"}],["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-3 gap-4 my-8","children":[["$","div",null,{"className":"bg-slate-800/20 border border-slate-700 p-5 rounded-lg","children":[["$","div",null,{"className":"text-xs text-slate-500 uppercase tracking-wider mb-3","children":"Layer 1"}],["$","h3",null,{"className":"text-white mt-0 mb-2 text-base","children":"EVM - Solidity"}],["$","p",null,{"className":"text-sm text-slate-400 mb-0","children":"Capital state, positions, token custody, bridge, and XCM settlement. Standard ethers.js / viem compatible."}]]}],["$","div",null,{"className":"bg-cyan-900/10 border border-cyan-500/30 p-5 rounded-lg","children":[["$","div",null,{"className":"text-xs text-slate-500 uppercase tracking-wider mb-3","children":"Layer 2"}],["$","h3",null,{"className":"text-cyan-400 mt-0 mb-2 text-base","children":"ink! Wasm - KreditAgent"}],["$","p",null,{"className":"text-sm text-slate-300 mb-0","children":["Deterministic credit scoring. Called atomically via SCALE cross-VM",["$","code",null,{"children":" staticcall"}]," from EVM market contracts in the same transaction."]}]]}],["$","div",null,{"className":"bg-purple-900/10 border border-purple-500/30 p-5 rounded-lg","children":[["$","div",null,{"className":"text-xs text-slate-500 uppercase tracking-wider mb-3","children":"Layer 3"}],["$","h3",null,{"className":"text-purple-400 mt-0 mb-2 text-base","children":"ink! PVM - AI Layer"}],["$","p",null,{"className":"text-sm text-slate-300 mb-0","children":"NeuralScorer, RiskAssessor, YieldMind. Called by the backend AI Engine; each computation emits a permanent on-chain event."}]]}]]}],["$","h3",null,{"children":"Layer 1 - EVM Contracts"}],["$","p",null,{"children":["All capital-bearing state lives in Solidity contracts on Polkadot Asset Hub EVM (Chain ID ",["$","code",null,{"children":"420420417"}],"). These contracts are optimised for gas-efficient financial primitives: token transfers, position accounting, collateral management, and event emission. They do not perform heavy computation."]}],["$","p",null,{"children":["Deployed contracts: ",["$","code",null,{"children":"KredioLending"}],", ",["$","code",null,{"children":"KredioPASMarket"}],","," ",["$","code",null,{"children":"KredioSwap"}],", ",["$","code",null,{"children":"KredioXCMSettler"}],","," ",["$","code",null,{"children":"KredioAccountRegistry"}],", ",["$","code",null,{"children":"GovernanceCache"}],","," ",["$","code",null,{"children":"KredioBridgeMinter"}],", ",["$","code",null,{"children":"EthBridgeInbox"}],","," ",["$","code",null,{"children":"PASOracle"}],", ",["$","code",null,{"children":"mUSDC"}],", ",["$","code",null,{"children":"YieldPool"}],"."]}],["$","h3",null,{"children":"Layer 2 - ink! Wasm (KreditAgent)"}],["$","p",null,{"children":[["$","code",null,{"children":"KreditAgent"}]," is compiled to WebAssembly and deployed on Asset Hub EVM alongside the Solidity contracts. Market contracts invoke it with a low-level"," ",["$","code",null,{"children":"staticcall"}]," carrying a SCALE-encoded 4-byte message selector:"]}],["$","pre",null,{"children":["$","code",null,{"children":"bytes4 constant SEL_COMPUTE_SCORE    = 0x3a518c00;\nbytes4 constant SEL_COLLATERAL_RATIO = 0xa70eec89;\nbytes4 constant SEL_INTEREST_RATE    = 0xb8dc60f2;\nbytes4 constant SEL_TIER             = 0x2b2bb477;"}]}],["$","p",null,{"children":"The cross-VM call executes atomically - same transaction, same block. The score, collateral ratio, and interest rate come back ABI-decoded and are immediately locked into the new position. No off-chain call, no latency, no trust assumption. This EVM-to-Wasm atomic interaction is unique to Polkadot's hybrid Asset Hub runtime."}],"$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b"]}],null,"$L1c"]}]
