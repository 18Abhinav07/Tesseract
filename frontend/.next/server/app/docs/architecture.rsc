16:["$","p",null,{"children":"The complete path from a user borrow to a full AI-layer assessment:"}]
17:["$","ol",null,{"children":[["$","li",null,{"children":["User calls ",["$","code",null,{"children":"KredioPASMarket.borrow(amount)"}]]}],["$","li",null,{"children":["Market calls ",["$","code",null,{"children":"KreditAgent.compute_score()"}]," via SCALE-encoded ",["$","code",null,{"children":"staticcall"}],"; receives score, collateral ratio, and rate in the same transaction"]}],["$","li",null,{"children":["Position is stored on-chain with locked parameters; ",["$","code",null,{"children":"Borrowed"}]," event emitted"]}],["$","li",null,{"children":["AI Engine polls the event; triggers ",["$","code",null,{"children":"NeuralScorer.infer()"}]," - emits ",["$","code",null,{"children":"ScoreInferred"}]]}],["$","li",null,{"children":["AI Engine triggers ",["$","code",null,{"children":"RiskAssessor.assess_position()"}]," - emits ",["$","code",null,{"children":"RiskAssessed"}]]}],["$","li",null,{"children":["On the next 50-block sweep, ",["$","code",null,{"children":"YieldMind.compute_allocation()"}]," runs over full pool state - emits ",["$","code",null,{"children":"AllocationComputed"}]]}]]}]
18:["$","p",null,{"children":"Steps 4–6 are permanent, queryable event records on Blockscout. The full credit and risk history of every borrower accumulates in the event log from their first interaction."}]
