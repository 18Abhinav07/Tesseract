e:["$","p",null,{"children":["Because ",["$","code",null,{"children":"KreditAgent"}]," is a Wasm contract, the scoring algorithm can be upgraded in place - incorporating governance signals in Phase 4, cross-chain history in Phase 6 - without redeploying ",["$","code",null,{"children":"KredioLending"}]," or"," ",["$","code",null,{"children":"KredioPASMarket"}],"."]}]
f:["$","h3",null,{"children":"Layer 3 - ink! PVM (AI Assessment)"}]
10:["$","p",null,{"children":"Three contracts compiled for PolkaVM run alongside the capital layer. They are called by the backend AI Engine - not by EVM contracts directly - and each emits a full on-chain event after every computation:"}]
11:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"NeuralScorer"}]," - neural cross-validation of the deterministic score; emits ",["$","code",null,{"children":"ScoreInferred"}]," with a confidence delta per borrower"]}],["$","li",null,{"children":[["$","strong",null,{"children":"RiskAssessor"}]," - forward-looking liquidation risk; emits ",["$","code",null,{"children":"RiskAssessed"}]," with estimated blocks-to-liquidation and recommended collateral top-up"]}],["$","li",null,{"children":[["$","strong",null,{"children":"YieldMind"}]," - optimal allocation across yield buckets; emits ",["$","code",null,{"children":"AllocationComputed"}]," with a documented reasoning code"]}]]}]
12:["$","h2",null,{"id":"backend","children":"Backend Service Layer"}]
13:["$","p",null,{"children":["A Node.js process on port ",["$","code",null,{"children":"3002"}]," coordinates all off-chain activity. It reads events from contracts and writes authorised transactions back, holding no protocol state of its own."]}]
14:["$","div",null,{"className":"overflow-x-auto my-6","children":["$","table",null,{"className":"min-w-full text-sm text-left","children":[["$","thead",null,{"className":"text-xs uppercase bg-slate-800/50 text-slate-400","children":["$","tr",null,{"children":[["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Service"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Role"}]]}]}],["$","tbody",null,{"className":"bg-slate-900/20","children":[["$","tr","Oracle Service",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono text-cyan-400 whitespace-nowrap","children":"Oracle Service"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Feeds PAS/USD prices to PASOracle on a configurable interval; self-aligns to 80% of the oracle staleness limit so data never expires"}]]}],["$","tr","Bridge Service",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono text-cyan-400 whitespace-nowrap","children":"Bridge Service"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Validates source-chain ETH deposits; cross-references CoinGecko and Chainlink (2% divergence tolerance); calls KredioBridgeMinter.processDeposit()"}]]}],["$","tr","Yield Strategy",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono text-cyan-400 whitespace-nowrap","children":"Yield Strategy"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Monitors pool utilisation; invests idle capital below 40% utilisation; partially recalls above 65%; full emergency recall above 80%"}]]}],["$","tr","AI Engine",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono text-cyan-400 whitespace-nowrap","children":"AI Engine"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Polls KredioLending events; calls NeuralScorer, RiskAssessor, and YieldMind on each event; runs a 50-block (~5 min) sweep of all active borrowers"}]]}],["$","tr","XCM Acknowledger",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono text-cyan-400 whitespace-nowrap","children":"XCM Acknowledger"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Monitors KredioXCMSettler for IntentSettled and IntentFailed events; closes the three-event acknowledgment loop for every cross-chain operation"}]]}],["$","tr","Protocol Ping",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono text-cyan-400 whitespace-nowrap","children":"Protocol Ping"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Keeps GovernanceCache and KredioAccountRegistry active with periodic background transactions; logs KredioSwap live quotes every 50 blocks"}]]}]]}]]}]}]
