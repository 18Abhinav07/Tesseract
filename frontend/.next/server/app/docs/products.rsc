e:["$","ul",null,{"children":[["$","li",null,{"children":"Live PAS/USD pricing from the on-chain Chainlink-compatible oracle determines collateral value at both borrow time and liquidation"}],["$","li",null,{"children":["Maximum loan-to-value: ",["$","strong",null,{"children":"65%"}]," of oracle-priced collateral, regardless of credit tier"]}],["$","li",null,{"children":"Borrow interest rate is dynamically adjusted by credit score - from 15% APR at ANON to 4% APR at DIAMOND"}],["$","li",null,{"children":"Oracle staleness guard: borrows and liquidations revert automatically if price data exceeds its configured staleness limit"}],["$","li",null,{"children":"Liquidation bonus: 8% of seized collateral paid to the liquidation caller"}],["$","li",null,{"children":["Admin-configurable risk parameters: ",["$","code",null,{"children":"ltvBps"}],", ",["$","code",null,{"children":"liqBonusBps"}],", and ",["$","code",null,{"children":"protocolFeeBps"}]," (capped at 20% by contract)"]}]]}]
