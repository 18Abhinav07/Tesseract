b:["$","$1","c",{"children":[["$","div",null,{"className":"animate-in fade-in duration-500","children":[["$","h1",null,{"children":"Core Products"}],["$","p",null,{"children":"Kredio deploys five distinct product surfaces on Polkadot Asset Hub EVM. Each contract is live, verified, and queryable on Blockscout today."}],["$","hr",null,{"className":"my-10 border-slate-800"}],["$","h2",null,{"id":"lending","children":"KredioLending - mUSDC Lending Market"}],["$","p",null,{"children":["The primary lending pool. Lenders supply mUSDC and earn continuous yield from borrower interest and the automated yield strategy. Borrowers post mUSDC as collateral and draw loans at the rate determined by their ",["$","code",null,{"children":"KreditAgent"}]," credit score."]}],["$","h3",null,{"children":"For Lenders"}],["$","ul",null,{"children":[["$","li",null,{"children":"Deposit mUSDC to earn yield from active borrower interest payments"}],["$","li",null,{"children":["Yield accumulates in real time via a share-based accumulator (",["$","code",null,{"children":"accYieldPerShare"}],"); harvestable at any time with constant gas cost regardless of total lender count"]}],["$","li",null,{"children":"Idle capital is automatically deployed to the external yield source when pool utilisation drops below 40%, recalled the moment borrowers demand it - lenders earn more without any additional action"}]]}],["$","h3",null,{"children":"For Borrowers"}],["$","ul",null,{"children":[["$","li",null,{"children":"Post mUSDC as collateral and borrow at your credit-tier rate"}],["$","li",null,{"children":["Collateral ratio and interest rate computed live at borrow time from ",["$","code",null,{"children":"KreditAgent"}]," and locked into the position at open - no oracle delay, no off-chain step"]}],["$","li",null,{"children":"Repay in full at any time; each repayment increments your on-chain repayment counter, improving future credit tier eligibility"}],["$","li",null,{"children":["Position health: ",["$","code",null,{"children":"healthRatio = collateral / (debt × ratioBps / 10000)"}],". When health drops below 1.0, any caller may liquidate and receive the collateral plus an 8% bonus"]}]]}],["$","div",null,{"className":"bg-slate-800/30 border border-slate-700 rounded-lg p-5 my-6","children":[["$","h4",null,{"className":"text-white mt-0 mb-3 font-medium","children":"Intelligent Yield Strategy"}],["$","p",null,{"className":"text-sm text-slate-300 mb-2","children":"The yield strategy service monitors real-time pool utilisation and moves capital across four zones:"}],["$","ul",null,{"className":"text-sm","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Below 40%"}]," - Invest idle capital; lenders earn the external yield rate on top of borrower interest"]}],["$","li",null,{"children":[["$","strong",null,{"children":"40%–65%"}]," - Hold current allocation; no rebalance required"]}],["$","li",null,{"children":[["$","strong",null,{"children":"65%–80%"}]," - Partially recall invested capital to restore liquidity headroom"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Above 80%"}]," - Immediately recall all invested capital; full liquidity buffer restored"]}]]}],["$","p",null,{"className":"text-sm text-slate-400 mb-0 mt-2","children":"A minimum 20% buffer of total deposits is always kept liquid. Rebalance actions under 100 mUSDC are skipped to prevent dust transactions."}]]}],["$","p",null,{"className":"text-sm text-slate-400","children":[["$","strong",null,{"children":"Contract:"}]," ",["$","code",null,{"children":"0x1eDaD1271FB9d1296939C6f4Fb762752b041C64E"}]," · Asset Hub EVM"]}],["$","hr",null,{"className":"my-10 border-slate-800"}],["$","h2",null,{"id":"pas-market","children":"KredioPASMarket - PAS Collateral Market"}],["$","p",null,{"children":["An independent market for borrowing mUSDC against native PAS token collateral. PAS is deposited as a ",["$","code",null,{"children":"payable"}]," call - no ERC-20 approve step required."]}],"$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20"]}],null,"$L21"]}]
