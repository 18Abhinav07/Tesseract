13:["$","ul",null,{"children":[["$","li",null,{"children":[["$","code",null,{"children":"quoteSwap(uint256 pasWei)"}]," - view-only pre-execution quote; exact mUSDC output before any on-chain commitment"]}],["$","li",null,{"children":[["$","code",null,{"children":"swap(uint256 minMUSDCOut)"}]," - executes with a slippage guard; reverts if output falls below the caller-specified minimum"]}],["$","li",null,{"children":"Fee: 30 basis points (0.3%), capped at a maximum of 100 bps (1%) by the contract"}],["$","li",null,{"children":"Swap is automatically suspended while the oracle is in crash mode, protecting users from stale pricing"}]]}]
