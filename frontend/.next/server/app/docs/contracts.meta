{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/contracts/layout,_N_T_/docs/contracts/page,_N_T_/docs/contracts/"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/contracts/__PAGE__",
    "/docs/contracts",
    "/docs",
    "/_index",
    "/_head"
  ]
}