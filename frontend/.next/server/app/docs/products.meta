{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/products/layout,_N_T_/docs/products/page,_N_T_/docs/products/"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/products/__PAGE__",
    "/docs/products",
    "/docs",
    "/_index",
    "/_head"
  ]
}