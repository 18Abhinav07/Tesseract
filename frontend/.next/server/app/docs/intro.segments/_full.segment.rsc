f:["$","div",null,{"className":"bg-purple-900/10 border border-purple-500/30 p-5 rounded-lg","children":[["$","h3",null,{"className":"text-purple-400 mt-0 mb-2","children":"ink! PVM - Continuous AI Assessment"}],["$","p",null,{"className":"text-sm text-slate-300 mb-0","children":["Three PVM contracts - ",["$","code",null,{"children":"NeuralScorer"}],", ",["$","code",null,{"children":"RiskAssessor"}],", and ",["$","code",null,{"children":"YieldMind"}]," - run continuously alongside the protocol, called by the backend AI Engine on every lending event. Each emits a permanent on-chain audit event after every computation."]}]]}]
