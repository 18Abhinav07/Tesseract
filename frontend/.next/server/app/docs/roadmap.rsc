43:I[897367,["/_next/static/chunks/d96012bcfc98706a.js","/_next/static/chunks/73e3194f06db260e.js"],"OutletBoundary"]
e:["$","h3",null,{"children":"Autonomous Yield Intelligence"}]
f:["$","p",null,{"children":[["$","code",null,{"children":"YieldMind"}]," determines where idle capital should sit at any given moment. It takes the current pool utilisation rate, the yield differential between custody and deployment, and the minimum liquidity buffer as inputs, and emits a recommended allocation split across internal custody and external yield sources. Each decision comes with a documented ",["$","code",null,{"children":"reasoning_code"}],"- an integer that maps to the specific market condition that drove the output - making every capital allocation decision auditable in retrospect."]}]
10:["$","h2",null,{"id":"tiers","children":"The Score in Six Tiers"}]
11:["$","p",null,{"children":"The credit score maps to six discrete borrowing tiers. Higher scores unlock better loan-to-value ratios and lower interest rates. On mainnet, the tier structure is designed as follows:"}]
12:["$","div",null,{"className":"overflow-x-auto my-6","children":["$","table",null,{"className":"min-w-full text-sm text-left","children":[["$","thead",null,{"className":"text-xs uppercase bg-slate-800/50 text-slate-400","children":["$","tr",null,{"children":[["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Tier"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Score Range"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Max LTV"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Interest Rate"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Access"}]]}]}],["$","tbody",null,{"className":"bg-slate-900/20","children":[["$","tr","Anon",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"Anon"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"0 – 19"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"30%"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"22%"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"New or unverified address"}]]}],["$","tr","Bronze",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"Bronze"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"20 – 39"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"45%"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"15%"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"1+ successful repayments"}]]}],["$","tr","Silver",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"Silver"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"40 – 59"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"60%"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"10%"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Established deposit and repayment history"}]]}],["$","tr","Gold",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"Gold"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"60 – 74"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"72%"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"7%"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Consistent borrower with low liquidation exposure"}]]}],["$","tr","Platinum",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"Platinum"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"75 – 89"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"80%"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"5%"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Long-tenure borrower; active governance participant"}]]}],["$","tr","Elite",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"Elite"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"90 – 100"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"85%"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"3%"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Top-decile borrower with verified on-chain identity"}]]}]]}]]}]}]
13:["$","p",null,{"children":"Movement between tiers is automatic and continuous. Every completed repayment increments the on-chain counter. Every deposit contributes to the deposit volume signal. Account age accrues passively. There is no application, no approval gate, and no human decision - the score is a function of behaviour, re-computed on every borrow."}]
14:["$","h2",null,{"id":"xcm-engine","children":"The XCM Settlement Engine"}]
15:["$","p",null,{"children":[["$","code",null,{"children":"KredioXCMSettler"}]," lets any Polkadot parachain with XCM Transact capability execute Kredio protocol actions without the user leaving their home chain. A borrower on Hydration or Bifrost sends a single XCM extrinsic with a compact-encoded intent payload. On Asset Hub, the settler decodes the intent and executes the corresponding protocol action in the same block - atomically, with full settlement guarantees."]}]
16:["$","p",null,{"children":["Every intent produces three on-chain events: received, dispatched, and acknowledged. This three-event lifecycle provides a complete, auditable record of every cross-chain protocol interaction. The intent separation matters - a ",["$","code",null,{"children":"SWAP_AND_LEND"}]," intent and a plain",["$","code",null,{"children":"DEPOSIT_LEND"}]," intent follow the same settlement path but carry different protocol implications; they are distinct by design rather than handled by a single catch-all route."]}]
17:["$","p",null,{"children":[["$","code",null,{"children":"FULL_EXIT"}]," is the most powerful intent: repay outstanding debt and withdraw collateral in a single XCM extrinsic from a remote chain. A cross-chain borrower who opened a position via XCM can close it entirely without switching chains or interacting with Asset Hub directly."]}]
18:["$","h2",null,{"children":"Mainnet: What Plugs In"}]
19:["$","h3",null,{"children":"Productive Collateral"}]
1a:["$","p",null,{"children":"On testnet, collateral is held in custody while a position is open. On mainnet, collateral will be deployed to yield while locked. The primary integration is DOT staked via Bifrost's liquid staking pool - a depositor posts DOT collateral, which is converted to vDOT earning approximately 15% APR, and the collateral balance is denominated in the live vDOT/USD oracle price. Collateral earns its keep while it secures the loan."}]
1b:["$","p",null,{"children":"This changes the protocol's capital efficiency fundamentally. A 200% collateralisation requirement against earning collateral is economically different from 200% against idle collateral - the yield offsets a meaningful fraction of the borrowing cost and reduces the net cost of borrowing for lower-tier users."}]
1c:["$","h3",null,{"children":"Real Yield for Depositors"}]
1d:["$","p",null,{"children":["YieldMind will route idle lending pool capital to external yield sources. The two primary targets at mainnet are Bifrost (conservative yield, liquid staking returns) and Hydration Omnipool (higher yield, liquidity provision exposure). YieldMind selects between them based on current protocol utilisation, pool depth, and volatility signals - not a hardcoded split. Depositors earn a blended yield from borrower interest plus the external routing decision, with the allocation logic fully auditable on-chain via the emitted ",["$","code",null,{"children":"AllocationComputed"}]," events."]}]
1e:["$","h3",null,{"children":"ETH Liquidity Without Intermediaries"}]
1f:["$","p",null,{"children":"The ETH bridge at mainnet will route through Snowbridge - the trustless, governance-secured bridge between Ethereum and Polkadot Asset Hub. Snowbridge eliminates the relayer trust assumption present in the testnet implementation; deposits are verified by Ethereum consensus light client proofs running inside Polkadot, with no custodian and no multisig. ETH holders gain access to the Kredio credit system without bridging through a centralised intermediary."}]
20:["$","h3",null,{"children":"Multi-Asset Collateral at Mainnet Depth"}]
21:["$","div",null,{"className":"overflow-x-auto my-6","children":["$","table",null,{"className":"min-w-full text-sm text-left","children":[["$","thead",null,{"className":"text-xs uppercase bg-slate-800/50 text-slate-400","children":["$","tr",null,{"children":[["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Asset"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Form"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Collateral Role"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Yield While Locked"}]]}]}],["$","tbody",null,{"className":"bg-slate-900/20","children":[["$","tr","DOT",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"DOT"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Native"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Primary collateral; converted to vDOT on deposit"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"~15% via Bifrost"}]]}],["$","tr","vDOT",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"vDOT"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Bifrost LST"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Direct vDOT collateral; LTV capped at oracle price"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Continuous accrual"}]]}],["$","tr","ETH",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"ETH"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Snowbridge wrapped"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"ETH-denominated borrow exposure"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Optional Hydration LP routing"}]]}],["$","tr","USDT",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"USDT"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Asset Hub native"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Stablecoin collateral; lower volatility discount applied"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Bifrost stable pools"}]]}],["$","tr","KSM",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"KSM"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"XCM from Kusama"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Kusama network collateral via XCM Settler intent"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Kusama staking yield"}]]}],["$","tr","HDX",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 font-mono font-medium text-cyan-300","children":"HDX"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Hydration native"}],["$","td",null,{"className":"px-4 py-3 text-slate-300","children":"Hydration-native collateral; oracle via Hydration price feed"}],["$","td",null,{"className":"px-4 py-3 text-slate-400 text-xs","children":"Omnipool farming"}]]}]]}]]}]}]
22:["$","h2",null,{"children":"The Connected Protocol"}]
23:["$","p",null,{"children":"Kredio is not a standalone lending pool. It is a credit layer that sits on top of the Polkadot ecosystem's native yield infrastructure. The XCM Settler accepts intent from parachains that have no lending market of their own. YieldMind routes capital to Hydration and Bifrost. The ETH bridge brings Ethereum capital into the credit system. The identity registry allows KILT credentials to deepen the score for users who choose to link them."}]
24:["$","p",null,{"children":"Each integration compresses the effective cost of Kredio's value proposition. Borrowers benefit from productive collateral; lenders benefit from external yield routing; parachains benefit from cross-chain credit access. The protocol is designed so that adding one integration makes every other integration more valuable."}]
25:["$","p",null,{"children":["The ",["$","code",null,{"children":"YieldMind"}]," allocation engine was built to make decisions, not to hold a number. On testnet the decisions are real - the logic, the reasoning codes, the conservative/balanced/aggressive split - but the destinations are mocked. On mainnet, every bucket has a named address and a real protocol behind it."]}]
26:["$","p",null,{"children":[["$","strong",null,{"children":"Conservative capital"}]," flows to Bifrost. Deposited DOT that is not actively serving collateral gets routed via the XCM settler to Bifrost's liquid staking layer, where it earns Polkadot native staking yield as vDOT. The capital remains recoverable via XCM at any time. There is no lock-up - the settler can recall it the moment utilization demands it."]}]
27:["$","p",null,{"children":[["$","strong",null,{"children":"Aggressive capital"}]," flows to Hydration's Omnipool. Surplus USDC that exceeds the protocol's minimum liquidity buffer enters Hydration's single-sided LP position, earning swap fees on every trade that passes through the pool. Hydration is the deepest native liquidity venue on Polkadot - its fee revenue reflects real market activity, not an assigned APY."]}]
28:["$","p",null,{"children":[["$","strong",null,{"children":"Snowbridge makes the third dimension possible."}]," Capital does not have to stay within the Polkadot ecosystem to work for Kredio's depositors. An Ethereum-side yield strategy - USDC deployed into Aave on Ethereum, ETH collateral earning staking rewards via Lido - becomes reachable through the same bridge infrastructure that brings ETH collateral onto Asset Hub. The XCM settler and the Snowbridge inbox already have a defined relationship in the codebase. Extending that relationship to move yield-seeking capital outbound is the same pipe, running in the other direction."]}]
29:["$","p",null,{"children":"The result is a lending protocol whose idle capital is never truly idle. Depositors earn from borrower interest, from staking yield on DOT collateral, from LP fees on surplus USDC, and in later phases from cross-chain yield positions opened via Snowbridge. Kredio does not offer a fixed yield number - it builds infrastructure that routes capital to wherever yield is currently best, governed by on-chain intelligence that adjusts with every block."}]
2a:["$","h2",null,{"id":"phases","children":"Development Phases"}]
2b:["$","div",null,{"className":"bg-slate-800/30 border border-slate-700 rounded-lg p-6 my-6","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"bg-cyan-900/50 border border-cyan-500/40 text-cyan-400 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider","children":"Phase 2"}],["$","span",null,{"className":"text-slate-500 text-sm","children":"Month 12"}]]}],["$","h3",null,{"className":"text-white mt-0 mb-3","children":"computeScore as Ecosystem Infrastructure"}],["$","p",null,{"className":"text-slate-300","children":["The ",["$","code",null,{"children":"KreditAgent.compute_score()"}]," call will be opened as an XCM-queryable endpoint accessible to any Polkadot parachain. Any protocol on the network - a money market on Hydration, an options vault on Acala, a lending product on Moonbeam - will be able to query a borrower's Kredio credit score directly via XCM, use it for underwriting decisions, and pass the result back to their own contract."]}],["$","p",null,{"className":"text-slate-300 mb-0","children":"This makes the Kredio score an ecosystem primitive. Protocols that integrate it get an instant risk signal for counterparty assessment; borrowers who have built a strong score carry that signal across the whole network. The score becomes portable reputation."}]]}]
2c:["$","div",null,{"className":"bg-slate-800/30 border border-purple-500/20 rounded-lg p-6 my-6","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"bg-purple-900/50 border border-purple-500/40 text-purple-400 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider","children":"Phase 3"}],["$","span",null,{"className":"text-slate-500 text-sm","children":"Month 18"}]]}],["$","h3",null,{"className":"text-white mt-0 mb-3","children":"Identity Deepens the Score"}],["$","p",null,{"className":"text-slate-300","children":["The ",["$","code",null,{"children":"KredioAccountRegistry"}]," currently verifies SR25519 signatures via the System precompile's ",["$","code",null,{"children":"sr25519Verify"}]," - live on Asset Hub, working today. SR25519 is the same cryptographic foundation that KILT Protocol's Decentralized Identity Provider is built on."]}],["$","p",null,{"className":"text-slate-300","children":"KILT DIP is live on Polkadot mainnet, funded by the Polkadot Treasury, and designed to be queried from any parachain via XCM. Adding it to Kredio is one step beyond what already works: the registry calls KILT's DIP after the SR25519 link, verifies credential validity, and stores the credential root hash on-chain alongside the EVM address link - immutable, auditable, and revocable if the attester revokes."}],["$","p",null,{"className":"text-slate-300","children":"Verified credentials become permanent score floors:"}],["$","div",null,{"className":"overflow-x-auto mt-4","children":["$","table",null,{"className":"min-w-full text-sm text-left","children":[["$","thead",null,{"className":"text-xs uppercase bg-slate-900/50 text-slate-500","children":["$","tr",null,{"children":[["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Credential"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Issued By"}],["$","th",null,{"className":"px-4 py-3 border-b border-slate-700","children":"Score Effect"}]]}]}],["$","tbody",null,{"children":[["$","tr","Proof of Humanity",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 text-slate-300 font-medium","children":"Proof of Humanity"}],["$","td",null,{"className":"px-4 py-3 text-slate-500","children":"SocialKYC / Deloitte"}],["$","td",null,{"className":"px-4 py-3 text-cyan-400 font-mono text-xs","children":"Score floor: 40 (permanent)"}]]}],["$","tr","Age verification",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 text-slate-300 font-medium","children":"Age verification"}],["$","td",null,{"className":"px-4 py-3 text-slate-500","children":"SocialKYC"}],["$","td",null,{"className":"px-4 py-3 text-cyan-400 font-mono text-xs","children":"+5 points"}]]}],["$","tr","Institutional entity",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 text-slate-300 font-medium","children":"Institutional entity"}],["$","td",null,{"className":"px-4 py-3 text-slate-500","children":"Licensed attester"}],["$","td",null,{"className":"px-4 py-3 text-cyan-400 font-mono text-xs","children":"Corporate Tier - custom LTV"}]]}],["$","tr","OpenGov participation",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 text-slate-300 font-medium","children":"OpenGov participation"}],["$","td",null,{"className":"px-4 py-3 text-slate-500","children":"On-chain (ConvictionVoting)"}],["$","td",null,{"className":"px-4 py-3 text-cyan-400 font-mono text-xs","children":"+1 per vote × conviction level"}]]}],["$","tr","24-month governance streak",{"className":"border-b border-slate-800","children":[["$","td",null,{"className":"px-4 py-3 text-slate-300 font-medium","children":"24-month governance streak"}],["$","td",null,{"className":"px-4 py-3 text-slate-500","children":"On-chain"}],["$","td",null,{"className":"px-4 py-3 text-cyan-400 font-mono text-xs","children":"+10 permanent bonus"}]]}]]}]]}]}],"$L41","$L42"]}]
2d:["$","div",null,{"className":"bg-slate-800/30 border border-amber-500/20 rounded-lg p-6 my-6","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"bg-amber-900/50 border border-amber-500/40 text-amber-400 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider","children":"Phase 4"}],["$","span",null,{"className":"text-slate-500 text-sm","children":"Month 24"}]]}],["$","h3",null,{"className":"text-white mt-0 mb-3","children":"The Neural Layer Becomes a Learning System"}],["$","p",null,{"className":"text-slate-300","children":["In Phase 4, the NeuralScorer's model weights shift from static, deployment-time parameters to a continuously updated training pipeline. The training signal is the on-chain event log itself - every ",["$","code",null,{"children":"RiskAssessed"}]," event with a subsequent liquidation or successful repayment outcome becomes a labelled sample."]}],["$","p",null,{"className":"text-slate-300","children":["Weekly gradient descent runs against the accumulated labeled dataset. New weights are proposed to KRED governance, voted on, and if approved, committed on-chain via ",["$","code",null,{"children":"updateWeights"}]," - with the training provenance hash published alongside the transaction. The model's entire learning history is permanent, on-chain, and auditable by anyone. The pipeline runs off-chain as a batch process and produces updated weight tensors submitted via the ",["$","code",null,{"children":"updateWeights"}]," message, rather than requiring full contract redeployments."]}],["$","p",null,{"className":"text-slate-300","children":["The RiskAssessor benefits in parallel - its liquidation timing estimates improve as the historical dataset grows. Early in the protocol's life, estimates are coarse. By Month 24, with thousands of completed positions, the ",["$","code",null,{"children":"estimated_blocks_to_liq"}]," signal becomes a materially accurate predictive tool."]}],["$","p",null,{"className":"text-slate-300 mb-0","children":"Crucially, the model upgrade mechanism is governed - no admin key can unilaterally push new model parameters. Weight updates require an on-chain proposal and confirmation period, keeping the AI layer inside the same governance framework as the rest of the protocol."}]]}]
2e:["$","div",null,{"className":"bg-slate-800/30 border border-emerald-500/20 rounded-lg p-6 my-6","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"bg-emerald-900/50 border border-emerald-500/40 text-emerald-400 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider","children":"Phase 5"}],["$","span",null,{"className":"text-slate-500 text-sm","children":"Month 30"}]]}],["$","h3",null,{"className":"text-white mt-0 mb-3","children":"KRED: Governance Owned by the Protocol's Best Users"}],["$","p",null,{"className":"text-slate-300","children":"KRED is the protocol's governance token. Distribution is not based on liquidity mining or participation incentives - it is based on credit score and protocol tenure. A borrower who held Gold tier for twelve months receives more governance authority than a capital allocator who deposited once and withdrew. The protocol's decision-makers are structurally selected to be its best actors."}],["$","p",null,{"className":"text-slate-300","children":"KRED governs:"}],["$","ul",null,{"className":"text-slate-300 list-disc ml-6 mb-4 space-y-1","children":[["$","li",null,{"children":"Tier boundary parameters (score range per tier, LTV ceilings)"}],["$","li",null,{"children":"Interest rate curves and the yield strategy allocation bands"}],["$","li",null,{"children":"Approved external yield destinations and maximum capital concentration per destination"}],["$","li",null,{"children":"NeuralScorer model update proposals and confirmation periods"}],["$","li",null,{"children":"New collateral asset onboarding and liquidation parameters"}]]}],["$","p",null,{"className":"text-slate-300 mt-4","children":[["$","strong",null,{"children":"The feedback loop:"}]," Voting with KRED earns governance participation credit in ",["$","code",null,{"children":"kredit_agent"}],". Better credit scores earn better borrow rates and a larger allocation in the next KRED distribution cycle. Token holders who stop participating see their governance credit bonus decay on a six-month halflife."]}],["$","p",null,{"className":"text-slate-300 mb-0 mt-4","children":"The protocol is not neutral about engagement. It is designed to make active participants structurally better off than passive ones - and it uses the same credit intelligence machinery to enforce that distinction. KRED holders are structurally incentivized to keep the model accurate, because an inaccurate credit model is the only thing that can destroy the protocol that generates their governance value."}]]}]
2f:["$","h2",null,{"children":"Why This Compounds"}]
30:["$","p",null,{"children":"Standard DeFi yield compounds trivially - principal grows, interest compounds on a larger base. The compounding in Kredio is structural. Credit reputation accumulates and cannot be instantaneously replicated. A borrower who reaches Elite tier over eighteen months of on-chain behaviour has built something that a new wallet cannot reproduce overnight. That asymmetry is non-trivial: it creates a meaningful incentive to protect reputation rather than exploit the protocol and restart."}]
31:["$","p",null,{"children":"The AI layer compounds separately. NeuralScorer confidence deltas accumulate across thousands of borrow events and become the training data for Phase 4 model updates. RiskAssessor's historical estimates versus actual liquidation outcomes become a ground truth dataset that makes future estimates more accurate. YieldMind allocation history becomes a backtestable track record that informs future strategy selection. The evidence base grows with every transaction."}]
32:["$","p",null,{"children":"The ecosystem integration compounds further still. When computeScore becomes an XCM endpoint in Phase 2, every parachain that queries it adds a new dimension to the network's understanding of that borrower - and every additional data point deepens the NeuralScorer's cross-validation capability."}]
33:["$","h2",null,{"children":"On the Build Choices"}]
34:["$","p",null,{"children":"There is a real engineering question behind every testnet demo: what is the minimum viable version of this feature that makes the underlying architecture visible and correct?"}]
35:["$","p",null,{"children":["For some features, a mock is the right answer. The mock yield pool in",["$","code",null,{"children":"KredioLending"}]," serves a clear purpose - it lets the YieldMind allocation logic run, produce events, and demonstrate its decision-making without requiring a live Bifrost endpoint that does not exist on Paseo testnet. The mock is a stand-in for an interface, not a substitute for the design."]}]
36:["$","p",null,{"children":"For other features, building an elaborate mock would have consumed the hackathon while producing something less useful. Connecting to a fake vDOT contract that accepts pretend DOT and returns simulated yield would have demonstrated the concept at the cost of the real work - which is the credit intelligence, the dual-mode scoring architecture, the XCM acknowledgment engine, and the event schema designed for long-term data accumulation. That work does not compress. It either exists or it does not."}]
37:["$","p",null,{"children":"The choice to build the XCM settler as a complete intent-acknowledgment engine - rather than a simple send-and-forget call - was made precisely because the failure modes of real cross-parachain operations are where integration work actually lives. A settler that dispatches and never follows up is not a cross-chain protocol. It is a one-way message system. The three-event lifecycle on every intent is not demonstration overhead. It is the operational standard that real cross-chain capital flows require."}]
38:["$","p",null,{"children":"When Bifrost is available as a destination, the settler receives a new address and a new call payload. The acknowledgment loop does not change. The event schema does not change. The YieldMind logic that decides when to deploy capital does not change. The integration work required to connect a real protocol is the work of writing a correct XCM message - not the work of replacing a scaffolded architecture with a real one."}]
39:["$","p",null,{"children":"The mocks that exist in this codebase are interface placeholders, present because the destination protocols do not exist on Paseo testnet. The infrastructure that exists is production-quality, designed to receive those protocols exactly as they are on mainnet. That is the distinction this build was optimized for."}]
3a:["$","div",null,{"className":"bg-cyan-900/10 border border-cyan-500/20 rounded-lg p-6 mt-10","children":[["$","p",null,{"className":"text-sm text-slate-300 mb-1 font-medium","children":"Currently live on testnet"}],["$","p",null,{"className":"text-sm text-slate-400 mb-0","children":"The testnet deployment is not a simplified preview of a different mainnet product. It is the same architecture running against constrained inputs - mocked where ecosystem protocols do not exist on Paseo, production-grade everywhere else."}]]}]
3b:["$","$L43",null,{"children":["$","$3f",null,{"name":"Next.MetadataOutlet","children":"$@44"}]}]
41:["$","p",null,{"className":"text-slate-300 mt-4","children":"These are floor raises, not ceiling raises. Verified identity does not inflate a score beyond what behavior earns - it provides a lower bound that persists through difficult periods. A protocol that prices anonymous wallets the same as identity-verified ones is mispricing risk. Kredio prices the difference correctly."}]
42:["$","p",null,{"className":"text-sm text-slate-400 mb-0","children":"Furthermore, Polkadot's ConvictionVoting precompile - confirmed live and queryable from Asset Hub contracts - makes OpenGov participation a natively available credit signal. A user who votes consistently in on-chain governance over an extended period is demonstrating long-term ecosystem commitment that correlates with repayment reliability. Kredio is the first DeFi protocol to use governance participation as a direct credit input."}]
