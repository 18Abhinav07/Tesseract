# Kredio Backend — environment variables
# Copy this file to .env and fill in real values before starting.

# ── Hub Testnet (oracle feeder) ──────────────────────────────────────────────
RPC=https://eth-rpc-testnet.polkadot.io/
ORACLE=
MARKET_ADDR=
KEY=
MODE=DEMO
# TICK_MS=60000

# ── ETH Bridge ───────────────────────────────────────────────────────────────
SEPOLIA_RPC=https://rpc.sepolia.org
# Fill in after deploying contracts:
INBOX_ADDR_11155111=
MINTER_ADDR=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002
# Comma-separated allowed CORS origins (leave empty to allow all in dev):
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
